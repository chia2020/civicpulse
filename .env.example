# CivicPulse local environment example.
# Copy this file to .env for local development. Never commit real secrets.

STREAMLIT_SERVER_PORT=8501

# Required cloud database settings.
SUPABASE_URL=https://your-project-ref.supabase.co

# Preferred for trusted server-side Streamlit deployments that refresh/write data.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Alternative only when Supabase RLS policies allow select/insert/update operations.
# SUPABASE_ANON_KEY=your-anon-or-publishable-key

SUPABASE_TABLE=issues

# Refresh live sources when the Streamlit site is opened.
CIVICPULSE_AUTO_REFRESH_ON_OPEN=true
CIVICPULSE_REFRESH_TTL_SECONDS=900
CIVICPULSE_SCRAPE_TARGET_LIMIT=8
CIVICPULSE_SCRAPE_ENTRY_LIMIT_PER_TARGET=8
CIVICPULSE_SCRAPE_TOTAL_TIMEOUT_SECONDS=45

# Optional AI fallback for extracting Hyderabad locality names from noisy posts.
# Keep this off for fast dashboard refreshes. Enable only when the key/quota is healthy.
CIVICPULSE_USE_GEMINI_LOCALITY=false
GEMINI_API_KEY=
